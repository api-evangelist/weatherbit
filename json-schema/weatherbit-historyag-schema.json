{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/HistoryAG",
  "title": "HistoryAG",
  "type": "object",
  "properties": {
    "lat": {
      "type": "number",
      "description": "Latitude",
