{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/weatherbit/refs/heads/main/json-structure/weatherbit-aq-current-structure.json",
  "name": "AQCurrent",
  "description": "AQCurrent schema from Weatherbit API",
  "type": "object",
  "properties": {
    "aqi": {
      "type": "int32",
      "description": "Cloud cover as a percentage (%)",
      "example": 100
    },
    "so2": {
      "type": "double",
      "description": "Concentration of SO2 (\u00b5g/m\u00b3)",
      "example": 50.0
    },
    "no2": {
      "type": "double",
      "description": "Concentration of NO2 (\u00b5g/m\u00b3)",
      "example": 25.0
    },
    "o3": {
      "type": "double",
      "description": "Concentration of O3 (\u00b5g/m\u00b3)",
      "example": 2.0
    },
    "pm25": {
      "type": "double",
      "description": "Concentration of PM 2.5 (\u00b5g/m\u00b3)",
      "example": 230.0
    },
    "pm10": {
      "type": "double",
      "description": "Concentration of PM 10 (\u00b5g/m\u00b3)",
      "example": 150.0
    }
  }
}